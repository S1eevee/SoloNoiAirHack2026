# Copy to .env and fill in your own values.

SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
# JWT_PRIVATE_KEY=   # PEM private key for RS256/ES256
# JWT_PUBLIC_KEY=    # PEM public key  for RS256/ES256

API_KEY=your-api-key-here
API_KEY_HASH_ALGO=sha256

# Local development defaults. Render overrides these for the single-service Docker deploy.
API_BASE=http://localhost:8000
PUBLIC_API_BASE=http://localhost:8000
FASTAPI_ROOT_PATH=

# Optional: set to a mounted Render disk path, e.g. /var/data.
# PERSISTENT_STORAGE_DIR=/var/data
# AUTH_DB_PATH=data/processed/auth.db
# ALERT_DB_PATH=data/processed/alerts.db
